# OCC — production .env template. Copy to .env on the server and fill values.
# Never commit the real .env to git.

APP_NAME=OCC
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://occ.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_IN
APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# Logging — never use 'single' in prod (no rotation). 'daily' rotates 14 days by default.
LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database — Postgres in production. Update host/port/credentials per environment.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=occ_production
DB_USERNAME=occ
DB_PASSWORD=

# Session — store in Redis for HA. Default file driver works for single-node.
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=occ_

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# Mail — Resend or SES recommended; SMTP is the fallback.
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="ops@gccommunication.in"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_KEY=

# Storage — S3-compatible (Cloudflare R2 / AWS S3) for uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=occ-prod
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OCC-specific
ALLOW_PUBLIC_REGISTRATION=false

# Tally bridge — enable + point at the Tally machine once configured
TALLY_ENABLED=false
TALLY_HOST=127.0.0.1
TALLY_PORT=9000
TALLY_COMPANY="GC Communication"
TALLY_TIMEOUT=30

# WhatsApp (AiSensy) — enable + drop API key once AiSensy account is approved.
# Templates must match those approved in AiSensy: order_confirmed, lr_shared,
# dispatched, delivery_confirmation, payment_received, payment_reminder.
WHATSAPP_ENABLED=false
WHATSAPP_API_KEY=
WHATSAPP_SENDER="GC Communication"
WHATSAPP_ENDPOINT=https://backend.aisensy.com/campaign/t1/api/v2

# OCR — evidence-image field extraction. Demo mode returns canned values per
# evidence kind so the UI flow works during dev. Flip OCR_ENABLED=true once
# an account is provisioned. Pick OCR_PROVIDER: textract (AWS) or gdai (Google).
OCR_ENABLED=false
OCR_PROVIDER=demo
OCR_API_KEY=
OCR_REGION=ap-south-1
# Document AI only:
OCR_ENDPOINT=
OCR_PROCESSOR_ID=
