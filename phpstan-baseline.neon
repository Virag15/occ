parameters:
	ignoreErrors:
		-
			message: '#^Parameter \#1 \$user of class Illuminate\\Auth\\Events\\Verified constructor expects Illuminate\\Contracts\\Auth\\MustVerifyEmail, App\\Models\\User\|null given\.$#'
			identifier: argument.type
			count: 1
			path: app/Http/Controllers/Auth/VerifyEmailController.php

		-
			message: '#^Access to an undefined property App\\Models\\Order\:\:\$c\.$#'
			identifier: property.notFound
			count: 1
			path: app/Http/Controllers/CustomerShowController.php

		-
			message: '#^Access to an undefined property App\\Models\\Order\:\:\$v\.$#'
			identifier: property.notFound
			count: 1
			path: app/Http/Controllers/CustomerShowController.php

		-
			message: '#^Access to an undefined property App\\Models\\Order\:\:\$ym\.$#'
			identifier: property.notFound
			count: 1
			path: app/Http/Controllers/CustomerShowController.php

		-
			message: '#^Access to an undefined property Illuminate\\Database\\Eloquent\\Model\:\:\$delivered_date\.$#'
			identifier: property.notFound
			count: 1
			path: app/Http/Controllers/OrderController.php

		-
			message: '#^Access to an undefined property Illuminate\\Database\\Eloquent\\Model\:\:\$dispatch_date\.$#'
			identifier: property.notFound
			count: 1
			path: app/Http/Controllers/OrderController.php

		-
			message: '#^Access to an undefined property Illuminate\\Database\\Eloquent\\Model\:\:\$id\.$#'
			identifier: property.notFound
			count: 1
			path: app/Http/Controllers/OrderController.php

		-
			message: '#^Using nullsafe property access "\?\-\>name" on left side of \?\? is unnecessary\. Use \-\> instead\.$#'
			identifier: nullsafe.neverNull
			count: 1
			path: app/Http/Controllers/OrderController.php

		-
			message: '#^Access to an undefined property App\\Models\\OrderItem\:\:\$qty\.$#'
			identifier: property.notFound
			count: 1
			path: app/Http/Controllers/ProductShowController.php

		-
			message: '#^Access to an undefined property App\\Models\\OrderItem\:\:\$revenue\.$#'
			identifier: property.notFound
			count: 1
			path: app/Http/Controllers/ProductShowController.php

		-
			message: '#^Access to an undefined property App\\Models\\OrderItem\:\:\$ym\.$#'
			identifier: property.notFound
			count: 1
			path: app/Http/Controllers/ProductShowController.php

		-
			message: '#^Using nullsafe property access "\?\-\>order_value" on left side of \?\? is unnecessary\. Use \-\> instead\.$#'
			identifier: nullsafe.neverNull
			count: 1
			path: app/Http/Controllers/ReportsController.php

		-
			message: '#^Access to an undefined property Illuminate\\Database\\Eloquent\\Model\:\:\$order_item_id\.$#'
			identifier: property.notFound
			count: 1
			path: app/Http/Controllers/ReturnController.php

		-
			message: '#^Access to an undefined property Illuminate\\Database\\Eloquent\\Model\:\:\$qty_returned\.$#'
			identifier: property.notFound
			count: 1
			path: app/Http/Controllers/ReturnController.php

		-
			message: '#^Negated boolean expression is always false\.$#'
			identifier: booleanNot.alwaysFalse
			count: 1
			path: app/Listeners/LogAuthEvents.php

		-
			message: '#^Cannot call method diffInMilliseconds\(\) on string\.$#'
			identifier: method.nonObject
			count: 1
			path: app/Models/TallySyncLog.php

		-
			message: '#^Using nullsafe property access "\?\-\>name" on left side of \?\? is unnecessary\. Use \-\> instead\.$#'
			identifier: nullsafe.neverNull
			count: 4
			path: app/Services/Tally/TallySyncService.php

		-
			message: '#^Right side of && is always true\.$#'
			identifier: booleanAnd.rightAlwaysTrue
			count: 1
			path: app/Support/ImageCompressor.php

		-
			message: '#^Offset ''lr'' on array\{status\: ''closed'', payment_status\: ''paid'', priority\: ''normal'', value\: 62000, brands\: array\{''Suraj''\}, days_ago\: 21, lr\: ''LR\-2026\-00398''\}\|array\{status\: ''delivered'', payment_status\: ''partial'', priority\: ''normal'', value\: 188000, brands\: array\{''Luker''\}, days_ago\: 10, lr\: ''LR\-2026\-00432''\}\|array\{status\: ''dispatched'', payment_status\: ''pending'', priority\: ''normal'', value\: 95000, brands\: array\{''Kaycee''\}, days_ago\: 5, lr\: ''LR\-2026\-00451''\} in isset\(\) always exists and is not nullable\.$#'
			identifier: isset.offset
			count: 1
			path: database/seeders/DatabaseSeeder.php

		-
			message: '#^Offset ''lr'' on array\{status\: ''closed'', payment_status\: ''paid'', priority\: ''normal'', value\: 62000, brands\: array\{''Suraj''\}, days_ago\: 21, lr\: ''LR\-2026\-00398''\}\|array\{status\: ''delivered'', payment_status\: ''partial'', priority\: ''normal'', value\: 188000, brands\: array\{''Luker''\}, days_ago\: 10, lr\: ''LR\-2026\-00432''\}\|array\{status\: ''dispatched'', payment_status\: ''pending'', priority\: ''normal'', value\: 95000, brands\: array\{''Kaycee''\}, days_ago\: 5, lr\: ''LR\-2026\-00451''\} on left side of \?\? always exists and is not nullable\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: database/seeders/DatabaseSeeder.php

		-
			message: '#^Offset 0\|1\|2\|3\|4 on array\{array\{qty\: 240, min\: 50, reorder\: 100, reason\: null\}, array\{qty\: 18, min\: 30, reorder\: 60, reason\: null\}, array\{qty\: 75, min\: 25, reorder\: 50, reason\: null\}, array\{qty\: 4, min\: 6, reorder\: 12, reason\: null\}, array\{qty\: \-12, min\: 10, reorder\: 20, reason\: ''Overbooked against…''\}\} on left side of \?\? always exists and is not nullable\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: database/seeders/DatabaseSeeder.php
